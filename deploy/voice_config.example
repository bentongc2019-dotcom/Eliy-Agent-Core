# Eliy Voice Session — API 配置模板
# 复制此文件为 .env 并填入你的 API Key
# ⚠️ 绝对不要将 .env 提交到 Git

# === LLM（必选其一） ===
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# === 语音服务 ===
# OpenAI Realtime API（推荐，低延迟全双工）
OPENAI_REALTIME_API_KEY=sk-your-openai-key-here
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# ElevenLabs TTS（高质量语音合成）
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-voice-id
# 推荐选择：成熟男性中文普通话声音

# Deepgram STT（低延迟语音识别）
DEEPGRAM_API_KEY=your-deepgram-key

# === Lip Sync ===
# SadTalker / Wav2Lip 本地服务端点（可选）
LIPSYNC_ENDPOINT=http://localhost:8080/api/lipsync
# 或使用 Web Audio API + viseme 映射（默认，无需外部服务）
LIPSYNC_MODE=viseme

# === 存储（可选） ===
DATABASE_URL=postgresql://user:pass@localhost:5432/eliy
VECTOR_STORE_URL=http://localhost:6333

# === 安全 ===
SESSION_SECRET=your-random-session-secret
CORS_ORIGIN=http://localhost:3000
